---
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import ProjectCard from '@components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);
const allTags = [...new Set(projects.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout
  title="Projects"
  description="Real tools for real problems — APIs, Chrome extensions, and products I've shipped."
  image="/og/projects.png"
>
  <section class="py-16 sm:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-4">
          <span class="inline-block w-8 h-[2px] bg-[var(--color-accent)]"></span>
          <span class="text-xs font-medium uppercase tracking-[0.15em] text-[var(--color-accent)]">Portfolio</span>
        </div>
        <h1 class="font-display text-4xl font-bold mb-4">Projects</h1>
        <p class="text-lg text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] max-w-2xl">
          Real tools for real problems — APIs, Chrome extensions, and products I've shipped.
        </p>
      </div>

      <!-- Tag filters -->
      {allTags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-10" id="tag-filters">
          <button
            data-tag="all"
            class="tag-btn active px-3 py-1.5 text-sm font-medium rounded-full border border-[var(--color-accent)] bg-[var(--color-accent)]/10 text-[var(--color-accent)] cursor-pointer transition-all duration-200"
          >
            All
          </button>
          {allTags.map((tag) => (
            <button
              data-tag={tag}
              class="tag-btn px-3 py-1.5 text-sm font-medium rounded-full border border-[var(--color-border-light)] dark:border-[var(--color-border-dark)] text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] cursor-pointer hover:border-[var(--color-accent)]/40 hover:text-[var(--color-accent)] transition-all duration-200"
            >
              {tag}
            </button>
          ))}
        </div>
      )}

      <div class="grid sm:grid-cols-2 gap-5" id="projects-grid">
        {projects.map((project) => (
          <div data-tags={JSON.stringify(project.data.tags)}>
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            url={project.data.url}
            github={project.data.github}
            tags={project.data.tags}
            status={project.data.status}
          />
          </div>
        ))}
      </div>

      {projects.length === 0 && (
        <p class="text-center text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] py-20">
          Projects coming soon!
        </p>
      )}
    </div>
  </section>
</BaseLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
    const projects = document.querySelectorAll<HTMLElement>('#projects-grid > div');
    if (!buttons.length || !projects.length) return;

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const tag = btn.dataset.tag;

        buttons.forEach((b) => {
          b.classList.remove('active', 'border-[var(--color-accent)]', 'bg-[var(--color-accent)]/10', 'text-[var(--color-accent)]');
          b.classList.add('border-[var(--color-border-light)]', 'dark:border-[var(--color-border-dark)]', 'text-[var(--color-text-secondary-light)]', 'dark:text-[var(--color-text-secondary-dark)]');
        });

        btn.classList.add('active', 'border-[var(--color-accent)]', 'bg-[var(--color-accent)]/10', 'text-[var(--color-accent)]');
        btn.classList.remove('border-[var(--color-border-light)]', 'dark:border-[var(--color-border-dark)]', 'text-[var(--color-text-secondary-light)]', 'dark:text-[var(--color-text-secondary-dark)]');

        projects.forEach((project) => {
          if (tag === 'all') {
            project.style.display = '';
          } else {
            const projectTags: string[] = JSON.parse(project.dataset.tags || '[]');
            project.style.display = projectTags.includes(tag!) ? '' : 'none';
          }
        });
      });
    });
  });
</script>
