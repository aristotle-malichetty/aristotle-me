---
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import { Download, Phone, Mail, Linkedin, MapPin, Briefcase, GraduationCap, Award } from '@lucide/astro';

const experience = [
  {
    title: 'Business Intelligence Analyst',
    company: 'Freelance',
    period: 'Aug 2025 - Present',
    bullets: [
      'Implement GA4 data layers and configure custom event tracking for multi-domain e-commerce properties',
      'Design UTM campaign attribution funnels connecting ad spend to revenue in Looker Studio',
      'Build automated lead sync workflows between CRMs, email platforms, and analytics tools via API integrations',
      'Develop interactive Looker Studio dashboards with BigQuery backends for real-time marketing KPI monitoring',
    ],
  },
  {
    title: 'BI Analyst Intern',
    company: 'SELAH LLC (DBA ILOLA)',
    period: 'Feb 2025 - May 2025',
    bullets: [
      'Built 5+ marketing performance dashboards in Looker Studio tracking conversion funnels and campaign ROI',
      'Reduced bounce rates by 40% through data-driven A/B testing and landing page optimization recommendations',
      'Conducted statistical A/B testing on email campaigns and ad creatives to improve conversion metrics',
    ],
  },
  {
    title: 'Digital Marketing Data Analyst / BI Consultant',
    company: 'Digital Domination',
    period: 'Jan 2022 - Aug 2023',
    bullets: [
      'Managed analytics and reporting for 10+ concurrent clients across healthcare, e-commerce, and SaaS verticals',
      'Built custom dashboards combining GA4, Google Ads, and CRM data for unified marketing attribution',
      'Drove a 20% average revenue increase across client portfolio through campaign optimization insights',
      'Developed multi-touch attribution models connecting ad spend to downstream revenue events',
    ],
  },
  {
    title: 'Digital Marketing Executive Intern',
    company: 'Internet Moguls, India',
    period: 'Jun 2021 - Dec 2021',
    bullets: [
      'Increased landing page conversion rates by 20% through iterative A/B testing and UX optimization',
      'Managed social media campaigns and content calendars across multiple client accounts',
    ],
  },
];

const skillGroups = [
  {
    label: 'Analytics',
    skills: ['GA4', 'Looker Studio', 'BigQuery', 'Power BI', 'Google Search Console'],
  },
  {
    label: 'Technical',
    skills: ['SQL', 'Python', 'Excel', 'CSV/Flat-File Data'],
  },
  {
    label: 'Marketing',
    skills: ['HubSpot', 'Go-to-Market', 'Email Marketing', 'A/B Testing', 'Funnel Analysis', 'Marketing Attribution'],
  },
  {
    label: 'AI & Automation',
    skills: ['Claude', 'Cursor', 'API Integrations', 'Workflow Automation'],
  },
];

const education = [
  {
    degree: 'M.S. in Business Analytics',
    school: 'University of New Haven, CT',
    detail: 'GPA 3.87',
    period: '2023 - 2025',
  },
  {
    degree: 'B.Sc. in Mathematics & Computer Science',
    school: 'Chaitanya Deemed to be University',
    period: '2019 - 2022',
  },
];

const certifications = [
  'Google Analytics 4 (2025)',
  'Six Sigma White Belt - CSSC (2024)',
];
---

<BaseLayout
  title="Resume"
  description="Aristotle Malichetty — Marketing Analyst & Technical Entrepreneur. 3+ years in digital marketing analytics, dashboard development, and SaaS."
>
  <section class="py-16 sm:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <!-- Header -->
      <div class="mb-12 stagger">
        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-6">
          <div>
            <h1 class="font-display text-4xl font-bold mb-2">Aristotle Malichetty</h1>
            <p class="text-lg text-[var(--color-accent)] font-medium">Marketing Analyst & Technical Entrepreneur</p>
          </div>
          <a
            href="/resume.pdf"
            target="_blank"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-[var(--color-accent)] text-white font-medium text-sm hover:bg-[var(--color-accent-hover)] transition-colors shrink-0"
          >
            <Download class="w-4 h-4" />
            Download PDF
          </a>
        </div>

        <p class="text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] leading-relaxed mb-6">
          Marketing Analyst with 3+ years of experience in digital marketing analytics, dashboard development, and client reporting. Building SaaS products and leveraging AI tools for analysis and workflow automation.
        </p>

        <div class="flex flex-wrap gap-4 text-sm text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)]">
          <span class="inline-flex items-center gap-1.5">
            <Phone class="w-4 h-4" />
            (203) 627-5068
          </span>
          <span class="inline-flex items-center gap-1.5">
            <Mail class="w-4 h-4" />
            <a href="mailto:mailaristotle@gmail.com" class="hover:text-[var(--color-accent)] transition-colors">mailaristotle@gmail.com</a>
          </span>
          <span class="inline-flex items-center gap-1.5">
            <Linkedin class="w-4 h-4" />
            <a href="https://linkedin.com/in/aristotlem" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-accent)] transition-colors">linkedin.com/in/aristotlem</a>
          </span>
        </div>
      </div>

      <!-- Experience -->
      <div class="mb-12">
        <div class="flex items-center gap-2 mb-6">
          <Briefcase class="w-5 h-5 text-[var(--color-accent)]" />
          <h2 class="font-display text-xl font-bold">Experience</h2>
        </div>
        <div class="space-y-8">
          {experience.map((job) => (
            <div class="relative pl-6 border-l-2 border-[var(--color-border-light)] dark:border-[var(--color-border-dark)]">
              <div class="absolute -left-[7px] top-1 w-3 h-3 rounded-full bg-[var(--color-accent)]" />
              <div class="mb-2">
                <h3 class="font-display font-semibold text-lg">{job.title}</h3>
                <p class="text-sm text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)]">
                  {job.company} &middot; {job.period}
                </p>
              </div>
              <ul class="space-y-1.5">
                {job.bullets.map((bullet) => (
                  <li class="text-sm text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] leading-relaxed pl-4 relative before:content-[''] before:absolute before:left-0 before:top-[9px] before:w-1.5 before:h-1.5 before:rounded-full before:bg-[var(--color-border-light)] dark:before:bg-[var(--color-border-dark)]">
                    {bullet}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>

      <!-- Skills -->
      <div class="mb-12">
        <div class="flex items-center gap-2 mb-6">
          <Award class="w-5 h-5 text-[var(--color-accent)]" />
          <h2 class="font-display text-xl font-bold">Skills</h2>
        </div>
        <div class="space-y-4">
          {skillGroups.map((group) => (
            <div>
              <p class="text-sm font-medium text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] mb-2">{group.label}</p>
              <div class="flex flex-wrap gap-2">
                {group.skills.map((skill) => (
                  <span class="inline-block px-3 py-1.5 text-sm rounded-lg border border-[var(--color-border-light)] dark:border-[var(--color-border-dark)] bg-[var(--color-card-elevated-light)] dark:bg-[var(--color-card-elevated-dark)]">
                    {skill}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Education -->
      <div class="mb-12">
        <div class="flex items-center gap-2 mb-6">
          <GraduationCap class="w-5 h-5 text-[var(--color-accent)]" />
          <h2 class="font-display text-xl font-bold">Education</h2>
        </div>
        <div class="space-y-4">
          {education.map((edu) => (
            <div class="p-4 rounded-xl border border-[var(--color-border-light)] dark:border-[var(--color-border-dark)] bg-[var(--color-card-elevated-light)] dark:bg-[var(--color-card-elevated-dark)]">
              <h3 class="font-display font-semibold">{edu.degree}</h3>
              <p class="text-sm text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)]">
                {edu.school} {edu.detail && `| ${edu.detail}`} | {edu.period}
              </p>
            </div>
          ))}
        </div>
      </div>

      <!-- Certifications -->
      <div>
        <div class="flex items-center gap-2 mb-6">
          <Award class="w-5 h-5 text-[var(--color-accent)]" />
          <h2 class="font-display text-xl font-bold">Certifications</h2>
        </div>
        <div class="flex flex-wrap gap-3">
          {certifications.map((cert) => (
            <span class="inline-block px-4 py-2 text-sm font-medium rounded-lg bg-[var(--color-accent)]/10 text-[var(--color-accent)]">
              {cert}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
