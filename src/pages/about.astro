---
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import { Code, Database, Brain, Rocket } from '@lucide/astro';

const workingOn = [
  {
    icon: Rocket,
    title: 'CallClaim.io',
    description: 'A SaaS platform for tracking and managing insurance claim calls.',
  },
  {
    icon: Brain,
    title: 'AI-Powered Workflows',
    description: 'Building automation pipelines with Claude, APIs, and serverless functions.',
  },
  {
    icon: Database,
    title: 'Marketing Analytics',
    description: 'Consulting on GA4, Looker Studio, and BigQuery implementations for clients.',
  },
];

const techStack = [
  'Astro', 'React', 'Next.js', 'Tailwind CSS', 'TypeScript',
  'Python', 'SQL', 'BigQuery', 'Cloudflare Workers',
  'GA4', 'Looker Studio', 'Claude AI', 'Cursor',
];
---

<BaseLayout
  title="About"
  description="I'm Aris — a marketing analyst turned builder. Learn more about my background, what I'm working on, and my tech stack."
>
  <section class="py-16 sm:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="stagger">
        <h1 class="font-display text-4xl font-bold mb-8">About</h1>

        <!-- Bio -->
        <div class="space-y-4 text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] leading-relaxed mb-14">
          <p>
            I'm <strong class="text-[var(--color-text-primary-light)] dark:text-[var(--color-text-primary-dark)]">Aristotle Malichetty</strong> — most people call me Aris. I'm a marketing analyst who fell in love with building things.
          </p>
          <p>
            My background is in digital marketing analytics — I've spent 3+ years helping companies understand their data through GA4, Looker Studio, and BigQuery. I've built dashboards for healthcare, e-commerce, and SaaS clients, and I've seen firsthand how good data can transform a business.
          </p>
          <p>
            But analytics is just half the story. I'm also a builder. I use AI tools like Claude and Cursor to rapidly prototype and ship products — from SaaS platforms to developer utilities. I believe the best analysts don't just report on data; they build the tools that generate it.
          </p>
          <p>
            I hold an M.S. in Business Analytics from the University of New Haven and a B.Sc. in Mathematics & Computer Science. When I'm not building, you'll find me exploring new AI tools, writing about the intersection of data and code, or working on my next project idea.
          </p>
        </div>

        <!-- What I'm Working On -->
        <div class="mb-14">
          <h2 class="font-display text-2xl font-bold mb-6">What I'm Working On</h2>
          <div class="space-y-4">
            {workingOn.map(({ icon: Icon, title, description }) => (
              <div class="flex gap-4 p-4 rounded-xl border border-[var(--color-border-light)] dark:border-[var(--color-border-dark)] bg-[var(--color-card-elevated-light)] dark:bg-[var(--color-card-elevated-dark)]">
                <Icon class="w-6 h-6 text-[var(--color-accent)] shrink-0 mt-0.5" />
                <div>
                  <h3 class="font-display font-semibold mb-1">{title}</h3>
                  <p class="text-sm text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)]">{description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Tech Stack -->
        <div>
          <h2 class="font-display text-2xl font-bold mb-6">Tech Stack</h2>
          <div class="flex flex-wrap gap-2">
            {techStack.map((tech) => (
              <span class="inline-block px-3 py-1.5 text-sm rounded-lg border border-[var(--color-border-light)] dark:border-[var(--color-border-dark)] bg-[var(--color-card-elevated-light)] dark:bg-[var(--color-card-elevated-dark)]">
                {tech}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
