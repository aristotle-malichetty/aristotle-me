---
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import { Mail, Linkedin, Twitter, Github, ArrowUpRight } from '@lucide/astro';

const contacts = [
  {
    icon: Mail,
    label: 'Email',
    value: 'mailaristotle@gmail.com',
    href: 'mailto:mailaristotle@gmail.com',
    description: 'The fastest way to talk about working together.',
  },
  {
    icon: Linkedin,
    label: 'LinkedIn',
    value: 'linkedin.com/in/aristotlem',
    href: 'https://linkedin.com/in/aristotlem',
    description: 'Connect with me professionally. I post about analytics and building in public.',
  },
  {
    icon: Twitter,
    label: 'X / Twitter',
    value: '@aristotlem',
    href: 'https://x.com/aristotlem',
    description: 'Where I share quick thoughts, project updates, and AI experiments.',
  },
  {
    icon: Github,
    label: 'GitHub',
    value: 'github.com/aristotle-malichetty',
    href: 'https://github.com/aristotle-malichetty',
    description: 'Open source projects and code experiments.',
  },
];
---

<BaseLayout
  title="Contact"
  description="Get in touch — email, LinkedIn, Twitter, or GitHub."
>
  <section class="py-16 sm:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="stagger">
        <div class="mb-12">
          <div class="flex items-center gap-3 mb-4">
            <span class="inline-block w-8 h-[2px] bg-[var(--color-accent)]"></span>
            <span class="text-xs font-medium uppercase tracking-[0.15em] text-[var(--color-accent)]">Contact</span>
          </div>
          <h1 class="font-display text-4xl font-bold mb-4">Get in touch</h1>
          <p class="text-lg text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)]">
            Have a question, project idea, or just want to say hi? Pick your preferred channel.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 gap-4">
          {contacts.map(({ icon: Icon, label, value, href, description }) => (
            <a
              href={href}
              target={href.startsWith('mailto') ? undefined : '_blank'}
              rel={href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
              data-copy-email={href.startsWith('mailto') ? value : undefined}
              class="group p-5 sm:p-6 rounded-xl border border-[var(--color-border-light)] dark:border-[var(--color-border-dark)] bg-[var(--color-card-elevated-light)] dark:bg-[var(--color-card-elevated-dark)] hover:border-[var(--color-accent)]/40 hover:shadow-[0_4px_20px_rgba(59,130,246,0.06)] dark:hover:shadow-[0_4px_20px_rgba(59,130,246,0.08)] transition-all duration-300"
            >
              <div class="flex items-start justify-between mb-4">
                <div class="w-10 h-10 rounded-lg bg-[var(--color-accent)]/10 flex items-center justify-center">
                  <Icon class="w-5 h-5 text-[var(--color-accent)]" />
                </div>
                <ArrowUpRight class="w-4 h-4 text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] opacity-0 group-hover:opacity-100 transition-all duration-200 group-hover:-translate-y-0.5 group-hover:translate-x-0.5" />
              </div>
              <h3 class="font-display font-semibold mb-1">{label}</h3>
              <p class="text-sm text-[var(--color-accent)] mb-2 font-medium">{value}</p>
              <p class="text-sm text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] leading-relaxed">
                {description}
              </p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
