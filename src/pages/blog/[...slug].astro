---
import BaseLayout from '@layouts/BaseLayout.astro';
import TagList from '@components/TagList.astro';
import { getCollection, render } from 'astro:content';
import { ArrowLeft, ArrowRight, Calendar, Clock, Link, Share2 } from '@lucide/astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const sorted = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  return sorted.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      prevPost: sorted[i + 1] || null,
      nextPost: sorted[i - 1] || null,
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const { Content, headings, remarkPluginFrontmatter } = await render(post);

const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const tocHeadings = headings.filter((h) => h.depth <= 3);
const postUrl = `https://aristotle.me/blog/${post.id}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  ...(post.data.updatedDate && { dateModified: post.data.updatedDate.toISOString() }),
  author: {
    '@type': 'Person',
    name: 'Aristotle Malichetty',
    url: 'https://aristotle.me',
  },
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.coverImage}
  type="article"
  publishedDate={post.data.date.toISOString()}
>
  <article class="py-12 sm:py-16">
    <div class="max-w-[680px] mx-auto px-4 sm:px-6">
      <!-- Back link -->
      <a
        href="/blog"
        class="inline-flex items-center gap-1.5 text-sm text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] hover:text-[var(--color-accent)] transition-colors mb-10"
      >
        <ArrowLeft class="w-4 h-4" />
        All posts
      </a>

      <!-- Article Header -->
      <header class="mb-8 stagger">
        {post.data.tags.length > 0 && <TagList tags={post.data.tags} class="mb-5" />}

        <h1 class="font-display text-3xl sm:text-[2.5rem] sm:leading-[1.15] font-bold tracking-tight mb-5">
          {post.data.title}
        </h1>

        <p class="text-lg sm:text-xl text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] leading-relaxed mb-8">
          {post.data.description}
        </p>

        <!-- Author + Meta row -->
        <div class="flex items-center justify-between py-6 border-y border-[var(--color-border-light)] dark:border-[var(--color-border-dark)]">
          <div class="flex items-center gap-3">
            <img
              src="/images/avatar.svg"
              alt="Aristotle Malichetty"
              class="w-10 h-10 rounded-full"
            />
            <div>
              <p class="text-sm font-semibold">Aristotle Malichetty</p>
              <div class="flex items-center gap-2 text-xs text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)]">
                <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
                {remarkPluginFrontmatter.readingTime && (
                  <>
                    <span>&middot;</span>
                    <span>{remarkPluginFrontmatter.readingTime}</span>
                  </>
                )}
              </div>
            </div>
          </div>

          <!-- Share buttons -->
          <div class="flex items-center gap-1">
            <button
              id="copy-link-btn"
              title="Copy link"
              class="p-2 rounded-lg text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] hover:bg-[var(--color-card-light)] dark:hover:bg-[var(--color-card-dark)] hover:text-[var(--color-accent)] transition-colors"
            >
              <Link class="w-4 h-4" />
            </button>
            <a
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(postUrl)}`}
              target="_blank"
              rel="noopener noreferrer"
              title="Share on X"
              class="p-2 rounded-lg text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] hover:bg-[var(--color-card-light)] dark:hover:bg-[var(--color-card-dark)] hover:text-[var(--color-accent)] transition-colors"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
              </svg>
            </a>
            <a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(postUrl)}`}
              target="_blank"
              rel="noopener noreferrer"
              title="Share on LinkedIn"
              class="p-2 rounded-lg text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] hover:bg-[var(--color-card-light)] dark:hover:bg-[var(--color-card-dark)] hover:text-[var(--color-accent)] transition-colors"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
              </svg>
            </a>
          </div>
        </div>
      </header>

      <!-- Cover image -->
      {post.data.coverImage && (
        <img
          src={post.data.coverImage}
          alt={post.data.title}
          class="w-full rounded-xl mb-10"
        />
      )}

      <!-- Table of Contents -->
      {tocHeadings.length > 2 && (
        <nav class="mb-10 p-5 rounded-xl bg-[var(--color-card-light)] dark:bg-[var(--color-card-dark)] border border-[var(--color-border-light)] dark:border-[var(--color-border-dark)]">
          <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] mb-3">
            Table of Contents
          </p>
          <ul class="space-y-1.5">
            {tocHeadings.map((heading) => (
              <li style={heading.depth === 3 ? 'padding-left: 1rem;' : ''}>
                <a
                  href={`#${heading.slug}`}
                  class:list={[
                    'block text-sm py-0.5 text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] hover:text-[var(--color-accent)] transition-colors',
                    heading.depth === 3 && 'text-xs',
                  ]}
                >
                  {heading.text}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )}

      <!-- Content -->
      <div class="prose">
        <Content />
      </div>

      <!-- Share footer -->
      <div class="mt-12 pt-8 border-t border-[var(--color-border-light)] dark:border-[var(--color-border-dark)]">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <img
              src="/images/avatar.svg"
              alt="Aristotle Malichetty"
              class="w-12 h-12 rounded-full"
            />
            <div>
              <p class="font-semibold text-sm">Written by Aristotle Malichetty</p>
              <p class="text-xs text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)]">
                Marketing analyst, SaaS builder, AI-powered developer.
              </p>
            </div>
          </div>
          <div class="flex items-center gap-1">
            <button
              id="copy-link-btn-footer"
              title="Copy link"
              class="p-2 rounded-lg text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] hover:bg-[var(--color-card-light)] dark:hover:bg-[var(--color-card-dark)] hover:text-[var(--color-accent)] transition-colors"
            >
              <Link class="w-4 h-4" />
            </button>
          </div>
        </div>
      </div>

      <!-- Prev/Next -->
      <nav class="mt-10 pt-8 border-t border-[var(--color-border-light)] dark:border-[var(--color-border-dark)] grid sm:grid-cols-2 gap-4">
        {prevPost ? (
          <a
            href={`/blog/${prevPost.id}`}
            class="group p-4 rounded-xl border border-[var(--color-border-light)] dark:border-[var(--color-border-dark)] hover:border-[var(--color-accent)]/50 transition-colors"
          >
            <span class="inline-flex items-center gap-1 text-xs text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] mb-1">
              <ArrowLeft class="w-3 h-3" /> Previous
            </span>
            <p class="font-medium text-sm group-hover:text-[var(--color-accent)] transition-colors line-clamp-1">
              {prevPost.data.title}
            </p>
          </a>
        ) : <div />}
        {nextPost && (
          <a
            href={`/blog/${nextPost.id}`}
            class="group p-4 rounded-xl border border-[var(--color-border-light)] dark:border-[var(--color-border-dark)] hover:border-[var(--color-accent)]/50 transition-colors text-right"
          >
            <span class="inline-flex items-center gap-1 text-xs text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] mb-1 justify-end">
              Next <ArrowRight class="w-3 h-3" />
            </span>
            <p class="font-medium text-sm group-hover:text-[var(--color-accent)] transition-colors line-clamp-1">
              {nextPost.data.title}
            </p>
          </a>
        )}
      </nav>
    </div>
  </article>

  <!-- Copy link script -->
  <script>
    function setupCopyButtons() {
      document.querySelectorAll('[id^="copy-link-btn"]').forEach((btn) => {
        btn.addEventListener('click', async () => {
          await navigator.clipboard.writeText(window.location.href);
          const original = btn.innerHTML;
          btn.innerHTML = '<svg class="w-4 h-4 text-green-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>';
          setTimeout(() => { btn.innerHTML = original; }, 2000);
        });
      });
    }
    setupCopyButtons();
    document.addEventListener('astro:after-swap', setupCopyButtons);
  </script>

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</BaseLayout>
