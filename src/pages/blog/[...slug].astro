---
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import TagList from '@components/TagList.astro';
import CommentSection from '@components/CommentSection.astro';
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import { ArrowLeft, ArrowRight, Calendar, Clock, Link, Share2, MessageCircle, X as XIcon, Mail, List } from '@lucide/astro';

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || '';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const sorted = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  return sorted.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      prevPost: sorted[i + 1] || null,
      nextPost: sorted[i - 1] || null,
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const { Content, headings } = await render(post);

const wordCount = (post.body || '').replace(/[#*`>\-\[\](){}|]/g, '').split(/\s+/).filter(Boolean).length;
const readingTime = `${Math.max(1, Math.ceil(wordCount / 250))} min read`;

const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});

const tocHeadings = headings.filter((h) => h.depth <= 3);
const postUrl = `https://aristotle.me/blog/${post.id}`;

const ogImage = `/og/${post.id}.png`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  ...(post.data.updatedDate && { dateModified: post.data.updatedDate.toISOString() }),
  image: `https://aristotle.me${ogImage}`,
  wordCount,
  inLanguage: 'en',
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': postUrl,
  },
  author: {
    '@type': 'Person',
    name: 'Aristotle Malichetty',
    url: 'https://aristotle.me',
  },
  publisher: {
    '@type': 'Person',
    name: 'Aristotle Malichetty',
    url: 'https://aristotle.me',
  },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://aristotle.me' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://aristotle.me/blog' },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: postUrl },
  ],
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={ogImage}
  type="article"
  publishedDate={post.data.date.toISOString()}
  modifiedDate={post.data.updatedDate?.toISOString()}
>
  <article class="py-12 sm:py-16">
    <!-- Header area — always centered 680px -->
    <div class="max-w-[680px] mx-auto px-4 sm:px-6">
      <!-- Article Header -->
      <header class="mb-8 stagger">
        <div class="flex items-center gap-3 mb-8">
          <a
            href="/blog"
            class="inline-flex items-center gap-1.5 text-sm text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] hover:text-[var(--color-accent)] transition-colors shrink-0"
          >
            <ArrowLeft class="w-4 h-4" />
            All posts
          </a>
          {post.data.tags.length > 0 && (
            <div class="flex-1 min-w-0 flex justify-end">
              <TagList tags={post.data.tags} class="justify-end" linked />
            </div>
          )}
        </div>

        <h1 class="font-display text-3xl sm:text-[2.5rem] sm:leading-[1.15] font-bold tracking-tight mb-5">
          {post.data.title}
        </h1>

        <p class="text-lg sm:text-xl text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] leading-relaxed mb-8">
          {post.data.description}
        </p>

        <!-- Author row -->
        <div class="flex items-center gap-3 py-5 border-y border-[var(--color-border-light)] dark:border-[var(--color-border-dark)]">
          <img
            src="/images/avatar.png"
            alt="Aristotle Malichetty"
            width="40"
            height="40"
            class="w-10 h-10 rounded-full"
          />
          <div class="flex items-center flex-wrap gap-x-1.5 text-sm">
            <a href="/about" class="font-semibold hover:text-[var(--color-accent)] transition-colors">Aristotle Malichetty</a>
            <span class="text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)]">&middot;</span>
            <span class="text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)]">{readingTime}</span>
            <span class="text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)]">&middot;</span>
            <time datetime={post.data.date.toISOString()} class="text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)]">{formattedDate}</time>
          </div>
        </div>

        <!-- Engagement row -->
        <div class="flex items-center justify-between py-3 border-b border-[var(--color-border-light)] dark:border-[var(--color-border-dark)]">
          <a href="#comments" class="inline-flex items-center gap-1.5 p-1.5 text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] hover:text-[var(--color-accent)] transition-colors" aria-label="Jump to comments">
            <MessageCircle class="w-5 h-5" />
            <span id="header-comment-count" class="text-sm"></span>
          </a>
          <button
            data-share-trigger
            class="inline-flex items-center gap-1.5 px-4 py-1.5 text-sm font-medium rounded-full border border-[var(--color-border-light)] dark:border-[var(--color-border-dark)] text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors"
          >
            <Share2 class="w-4 h-4" />
            Share
          </button>
        </div>
      </header>

      <!-- Cover image -->
      {post.data.coverImage && (
        <Image
          src={post.data.coverImage}
          alt={post.data.title}
          class="w-full rounded-xl mb-10"
          widths={[480, 768, 1024]}
          sizes="(max-width: 680px) 100vw, 680px"
          loading="eager"
        />
      )}

    </div>

    <!-- Content area — relative wrapper so sticky TOC has height context -->
    <div class="max-w-[680px] mx-auto px-4 sm:px-6 relative">
      <!-- Desktop sticky TOC (Substack-style) — positioned to the left -->
      {tocHeadings.length > 2 && (
        <div class="hidden xl:block absolute right-full top-0 h-full mr-6">
          <div class="sticky top-24 flex items-start" id="toc-desktop">
            <!-- Minimize toggle (dash indicators) -->
            <button
              id="toc-toggle"
              class="flex flex-col items-center gap-[11px] py-3 pr-3 group shrink-0"
              title="Toggle contents"
              aria-label="Toggle table of contents"
              aria-expanded="true"
              aria-controls="toc-card"
            >
              {tocHeadings.map(() => (
                <span class="block w-4 h-[2.5px] rounded-full bg-[var(--color-text-secondary-light)]/25 dark:bg-[var(--color-text-secondary-dark)]/25 group-hover:bg-[var(--color-text-secondary-light)]/60 dark:group-hover:bg-[var(--color-text-secondary-dark)]/60 transition-colors duration-200" />
              ))}
            </button>

            <!-- TOC card -->
            <nav
              id="toc-card"
              aria-label="Table of contents"
              class="w-[230px] py-4 px-5 rounded-xl bg-[var(--color-card-light)] border border-[var(--color-border-light)]"
            >
              <p class="text-[11px] font-bold uppercase tracking-widest text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] mb-3.5">
                Contents
              </p>
              <ul class="space-y-0.5">
                {tocHeadings.map((heading) => (
                  <li>
                    <a
                      href={`#${heading.slug}`}
                      data-toc-link={heading.slug}
                      class:list={[
                        'toc-link block text-[13px] leading-relaxed py-0.5 truncate transition-colors duration-200',
                        heading.depth === 3 && 'pl-3.5 text-[12px]',
                      ]}
                    >
                      {heading.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>
        </div>
      )}

      <!-- Content -->
      <div class="prose">
        <Content />
      </div>

      <!-- Share footer -->
      <div class="mt-12 pt-8 border-t border-[var(--color-border-light)] dark:border-[var(--color-border-dark)]">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <img
              src="/images/avatar.png"
              alt="Aristotle Malichetty"
              width="48"
              height="48"
              class="w-12 h-12 rounded-full"
            />
            <div>
              <p class="font-semibold text-sm">Written by <a href="/about" class="hover:text-[var(--color-accent)] transition-colors">Aristotle Malichetty</a></p>
              <p class="text-xs text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)]">
                Analytics and code. I build what the problem needs.
              </p>
            </div>
          </div>
          <button
            data-share-trigger
            class="inline-flex items-center gap-1.5 px-4 py-1.5 text-sm font-medium rounded-full border border-[var(--color-border-light)] dark:border-[var(--color-border-dark)] text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors"
          >
            <Share2 class="w-4 h-4" />
            Share
          </button>
        </div>
      </div>

      <!-- Comments -->
      <CommentSection slug={post.id} turnstileSiteKey={turnstileSiteKey} />

      <!-- Prev/Next -->
      <nav aria-label="Previous and next posts" class="mt-10 pt-8 border-t border-[var(--color-border-light)] dark:border-[var(--color-border-dark)] grid sm:grid-cols-2 gap-4">
        {prevPost ? (
          <a
            href={`/blog/${prevPost.id}`}
            class="group p-4 rounded-xl border border-[var(--color-border-light)] dark:border-[var(--color-border-dark)] hover:border-[var(--color-accent)]/50 transition-colors"
          >
            <span class="inline-flex items-center gap-1 text-xs text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] mb-1">
              <ArrowLeft class="w-3 h-3" /> Previous
            </span>
            <p class="font-medium text-sm group-hover:text-[var(--color-accent)] transition-colors line-clamp-1">
              {prevPost.data.title}
            </p>
          </a>
        ) : <div />}
        {nextPost && (
          <a
            href={`/blog/${nextPost.id}`}
            class="group p-4 rounded-xl border border-[var(--color-border-light)] dark:border-[var(--color-border-dark)] hover:border-[var(--color-accent)]/50 transition-colors text-right"
          >
            <span class="inline-flex items-center gap-1 text-xs text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] mb-1 justify-end">
              Next <ArrowRight class="w-3 h-3" />
            </span>
            <p class="font-medium text-sm group-hover:text-[var(--color-accent)] transition-colors line-clamp-1">
              {nextPost.data.title}
            </p>
          </a>
        )}
      </nav>
    </div>
  </article>

  <!-- Share Modal -->
  <div
    id="share-modal"
    class="fixed inset-0 z-[100] flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-200"
    role="dialog"
    aria-modal="true"
    aria-labelledby="share-modal-title"
    aria-hidden="true"
    inert
  >
    <!-- Backdrop -->
    <div id="share-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

    <!-- Modal card -->
    <div
      id="share-card"
      class="relative w-full max-w-md mx-4 rounded-2xl bg-[var(--color-card-elevated-light)] dark:bg-[var(--color-card-elevated-dark)] shadow-2xl p-6 scale-95 transition-transform duration-200"
    >
      <!-- Header -->
      <div class="flex items-center justify-between mb-5">
        <h2 id="share-modal-title" class="text-lg font-semibold">Share this post</h2>
        <button id="share-close" class="p-1.5 rounded-lg text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] hover:bg-[var(--color-card-light)] dark:hover:bg-[var(--color-card-dark)] transition-colors" aria-label="Close">
          <XIcon class="w-5 h-5" />
        </button>
      </div>

      <!-- Post preview card -->
      <div class="rounded-xl overflow-hidden bg-[var(--color-card-light)] dark:bg-[var(--color-card-dark)] mb-6">
        <img src={ogImage} alt={post.data.title} class="w-full object-cover" />
      </div>

      <!-- Share options -->
      <div class="grid grid-cols-4 gap-4">
        <!-- Copy link -->
        <button id="share-copy-link" class="flex flex-col items-center gap-2.5 group">
          <span class="w-12 h-12 flex items-center justify-center rounded-full bg-[var(--color-surface-light)] dark:bg-[var(--color-card-dark)] group-hover:bg-[var(--color-accent)]/10 group-hover:text-[var(--color-accent)] transition-colors">
            <Link class="w-5 h-5" />
          </span>
          <span class="text-xs text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] group-hover:text-[var(--color-accent)] transition-colors">Copy link</span>
        </button>

        <!-- X / Twitter -->
        <a
          href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(postUrl)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-col items-center gap-2.5 group"
        >
          <span class="w-12 h-12 flex items-center justify-center rounded-full bg-[var(--color-surface-light)] dark:bg-[var(--color-card-dark)] group-hover:bg-[var(--color-accent)]/10 group-hover:text-[var(--color-accent)] transition-colors">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
          </span>
          <span class="text-xs text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] group-hover:text-[var(--color-accent)] transition-colors">X</span>
        </a>

        <!-- Email -->
        <a
          href={`mailto:?subject=${encodeURIComponent(post.data.title)}&body=${encodeURIComponent(`Check out this post: ${postUrl}`)}`}
          class="flex flex-col items-center gap-2.5 group"
        >
          <span class="w-12 h-12 flex items-center justify-center rounded-full bg-[var(--color-surface-light)] dark:bg-[var(--color-card-dark)] group-hover:bg-[var(--color-accent)]/10 group-hover:text-[var(--color-accent)] transition-colors">
            <Mail class="w-5 h-5" />
          </span>
          <span class="text-xs text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] group-hover:text-[var(--color-accent)] transition-colors">Email</span>
        </a>

        <!-- LinkedIn -->
        <a
          href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(postUrl)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-col items-center gap-2.5 group"
        >
          <span class="w-12 h-12 flex items-center justify-center rounded-full bg-[var(--color-surface-light)] dark:bg-[var(--color-card-dark)] group-hover:bg-[var(--color-accent)]/10 group-hover:text-[var(--color-accent)] transition-colors">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </span>
          <span class="text-xs text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] group-hover:text-[var(--color-accent)] transition-colors">LinkedIn</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Mobile TOC -->
  {tocHeadings.length > 2 && (
    <>
      {/* Floating button */}
      <button
        id="mobile-toc-btn"
        class="fixed bottom-6 right-4 z-50 xl:hidden w-12 h-12 flex items-center justify-center rounded-full bg-[var(--color-accent)] text-white shadow-lg hover:bg-[var(--color-accent-hover)] transition-colors"
        aria-label="Table of contents"
        aria-expanded="false"
        aria-controls="mobile-toc-overlay"
      >
        <List class="w-5 h-5" />
      </button>

      {/* Bottom sheet */}
      <div
        id="mobile-toc-overlay"
        class="fixed inset-0 z-[100] xl:hidden opacity-0 pointer-events-none transition-opacity duration-200"
        role="dialog"
        aria-modal="true"
        aria-label="Table of contents"
        aria-hidden="true"
        inert
      >
        {/* Backdrop */}
        <div id="mobile-toc-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

        {/* Sheet */}
        <div
          id="mobile-toc-sheet"
          class="absolute bottom-0 left-0 right-0 max-h-[60vh] rounded-t-2xl bg-[var(--color-card-elevated-light)] dark:bg-[var(--color-card-elevated-dark)] shadow-2xl mobile-toc-sheet-hidden overflow-hidden flex flex-col transition-transform duration-300 ease-out"
        >
          {/* Header */}
          <div class="flex items-center justify-between px-5 py-4 border-b border-[var(--color-border-light)] dark:border-[var(--color-border-dark)] shrink-0">
            <p class="text-[11px] font-bold uppercase tracking-widest text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)]">
              Contents
            </p>
            <button id="mobile-toc-close" class="p-1.5 rounded-lg text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] hover:bg-[var(--color-card-light)] dark:hover:bg-[var(--color-card-dark)] transition-colors" aria-label="Close">
              <XIcon class="w-5 h-5" />
            </button>
          </div>

          {/* Links */}
          <nav aria-label="Table of contents" class="overflow-y-auto overscroll-contain px-5 py-4">
            <ul class="space-y-0.5">
              {tocHeadings.map((heading) => (
                <li>
                  <a
                    href={`#${heading.slug}`}
                    data-toc-link={heading.slug}
                    class:list={[
                      'toc-link block text-[13px] leading-relaxed py-1.5 truncate transition-colors duration-200',
                      heading.depth === 3 && 'pl-3.5 text-[12px]',
                    ]}
                  >
                    {heading.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </div>
      </div>
    </>
  )}

  <!-- TOC scripts -->
  <script>
    function setupTocHighlight() {
      const tocLinks = document.querySelectorAll('[data-toc-link]');
      if (!tocLinks.length) return;

      const headingIds = Array.from(tocLinks).map((link) => link.getAttribute('data-toc-link'));
      const headingElements = headingIds
        .map((id) => document.getElementById(id!))
        .filter(Boolean) as HTMLElement[];

      if (!headingElements.length) return;

      function setActive(id: string) {
        tocLinks.forEach((link) => {
          if (link.getAttribute('data-toc-link') === id) {
            link.classList.add('active');
          } else {
            link.classList.remove('active');
          }
        });
      }

      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              setActive(entry.target.id);
              break;
            }
          }
        },
        { rootMargin: '-80px 0px -75% 0px', threshold: 0 },
      );

      headingElements.forEach((el) => observer.observe(el));

      // Set initial active state
      if (headingElements[0]) setActive(headingElements[0].id);

      return observer;
    }

    function setupTocToggle() {
      const toggle = document.getElementById('toc-toggle');
      const card = document.getElementById('toc-card');
      if (!toggle || !card) return;

      toggle.addEventListener('click', () => {
        card.classList.toggle('collapsed');
        const isExpanded = !card.classList.contains('collapsed');
        toggle.setAttribute('aria-expanded', String(isExpanded));
      });
    }

    function setupMobileToc() {
      const btn = document.getElementById('mobile-toc-btn');
      const overlay = document.getElementById('mobile-toc-overlay');
      const backdrop = document.getElementById('mobile-toc-backdrop');
      const sheet = document.getElementById('mobile-toc-sheet');
      const closeBtn = document.getElementById('mobile-toc-close');

      if (!btn || !overlay || !sheet) return;

      function openSheet() {
        overlay!.classList.remove('pointer-events-none', 'opacity-0');
        overlay!.classList.add('opacity-100');
        overlay!.setAttribute('aria-hidden', 'false');
        overlay!.removeAttribute('inert');
        sheet!.classList.remove('mobile-toc-sheet-hidden');
        btn!.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      }

      function closeSheet() {
        overlay!.classList.add('opacity-0', 'pointer-events-none');
        overlay!.classList.remove('opacity-100');
        overlay!.setAttribute('aria-hidden', 'true');
        overlay!.setAttribute('inert', '');
        sheet!.classList.add('mobile-toc-sheet-hidden');
        btn!.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }

      btn.addEventListener('click', openSheet);
      backdrop?.addEventListener('click', closeSheet);
      closeBtn?.addEventListener('click', closeSheet);

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && overlay!.getAttribute('aria-hidden') === 'false') {
          closeSheet();
        }
      });

      // Tapping a link: smooth scroll + close
      sheet.querySelectorAll('a[data-toc-link]').forEach((link) => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const slug = (link as HTMLAnchorElement).getAttribute('data-toc-link');
          const target = slug ? document.getElementById(slug) : null;
          if (target) {
            closeSheet();
            setTimeout(() => {
              const top = target.getBoundingClientRect().top + window.scrollY - 80;
              window.scrollTo({ top, behavior: 'smooth' });
            }, 200);
          }
        });
      });
    }

    let tocObserver: IntersectionObserver | undefined;

    function initToc() {
      tocObserver?.disconnect();
      tocObserver = setupTocHighlight() || undefined;
      setupTocToggle();
      setupMobileToc();
    }

    initToc();
    document.addEventListener('astro:after-swap', initToc);
  </script>

  <!-- Share modal script -->
  <script>
    function setupShareModal() {
      const modal = document.getElementById('share-modal');
      const card = document.getElementById('share-card');
      const backdrop = document.getElementById('share-backdrop');
      const closeBtn = document.getElementById('share-close');
      const copyBtn = document.getElementById('share-copy-link');
      const triggers = document.querySelectorAll('[data-share-trigger]');

      if (!modal || !card) return;

      function openModal() {
        modal!.classList.remove('pointer-events-none', 'opacity-0');
        modal!.classList.add('opacity-100');
        modal!.setAttribute('aria-hidden', 'false');
        modal!.removeAttribute('inert');
        card!.classList.remove('scale-95');
        card!.classList.add('scale-100');
        document.body.style.overflow = 'hidden';
      }

      function closeModal() {
        modal!.classList.add('opacity-0', 'pointer-events-none');
        modal!.classList.remove('opacity-100');
        modal!.setAttribute('aria-hidden', 'true');
        modal!.setAttribute('inert', '');
        card!.classList.add('scale-95');
        card!.classList.remove('scale-100');
        document.body.style.overflow = '';
      }

      triggers.forEach((btn) => btn.addEventListener('click', openModal));
      closeBtn?.addEventListener('click', closeModal);
      backdrop?.addEventListener('click', closeModal);

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal!.getAttribute('aria-hidden') === 'false') {
          closeModal();
        }
      });

      copyBtn?.addEventListener('click', async () => {
        await navigator.clipboard.writeText(window.location.href);
        const label = copyBtn.querySelector('span:last-child');
        if (label) {
          label.textContent = 'Copied!';
          label.classList.add('text-green-500');
          setTimeout(() => {
            label.textContent = 'Copy link';
            label.classList.remove('text-green-500');
          }, 2000);
        }
      });
    }

    setupShareModal();
    document.addEventListener('astro:after-swap', setupShareModal);
  </script>

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
</BaseLayout>
