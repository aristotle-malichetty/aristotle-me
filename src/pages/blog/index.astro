---
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import BlogCard from '@components/BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const postsWithReadingTime = posts.map((post) => {
  const wordCount = (post.body || '').replace(/[#*`>\-\[\](){}|]/g, '').split(/\s+/).filter(Boolean).length;
  const readingTime = `${Math.max(1, Math.ceil(wordCount / 250))} min read`;
  return { post, readingTime };
});

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout
  title="Blog"
  description="Thoughts on marketing analytics, building SaaS products, and AI-powered development."
  image="/og/blog.png"
>
  <section class="py-16 sm:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-4">
          <span class="inline-block w-8 h-[2px] bg-[var(--color-accent)]"></span>
          <span class="text-xs font-medium uppercase tracking-[0.15em] text-[var(--color-accent-hover)]">Blog</span>
        </div>
        <h1 class="font-display text-4xl font-bold mb-4">Writing</h1>
        <p class="text-lg text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] max-w-2xl">
          Thoughts on marketing analytics, building SaaS products, and AI-powered development.
        </p>
      </div>

      <!-- Tag filters -->
      {allTags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-10" id="tag-filters">
          <button
            data-tag="all"
            class="tag-btn active px-3 py-1.5 text-sm font-medium rounded-full border border-[var(--color-accent)] bg-[var(--color-accent)]/10 text-[var(--color-accent-hover)] cursor-pointer transition-all duration-200"
          >
            All
          </button>
          {allTags.map((tag) => (
            <button
              data-tag={tag}
              class="tag-btn px-3 py-1.5 text-sm font-medium rounded-full border border-[var(--color-border-light)] dark:border-[var(--color-border-dark)] text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] cursor-pointer hover:border-[var(--color-accent)]/40 hover:text-[var(--color-accent)] transition-all duration-200"
            >
              {tag}
            </button>
          ))}
        </div>
      )}

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 max-w-3xl lg:max-w-5xl mx-auto" id="posts-grid">
        {postsWithReadingTime.map(({ post, readingTime }) => (
          <div data-tags={JSON.stringify(post.data.tags)}>
            <BlogCard
              slug={post.id}
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              tags={post.data.tags}
              readingTime={readingTime}
            />
          </div>
        ))}
      </div>

      {posts.length === 0 && (
        <p class="text-center text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] py-20">
          No posts yet. Check back soon!
        </p>
      )}
    </div>
  </section>
</BaseLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
    const posts = document.querySelectorAll<HTMLElement>('#posts-grid > div');
    if (!buttons.length || !posts.length) return;

    function selectTag(tag: string) {
      buttons.forEach((b) => {
        b.classList.remove('active', 'border-[var(--color-accent)]', 'bg-[var(--color-accent)]/10', 'text-[var(--color-accent-hover)]');
        b.classList.add('border-[var(--color-border-light)]', 'dark:border-[var(--color-border-dark)]', 'text-[var(--color-text-secondary-light)]', 'dark:text-[var(--color-text-secondary-dark)]');
      });

      const active = Array.from(buttons).find((b) => b.dataset.tag === tag) || buttons[0];
      active.classList.add('active', 'border-[var(--color-accent)]', 'bg-[var(--color-accent)]/10', 'text-[var(--color-accent-hover)]');
      active.classList.remove('border-[var(--color-border-light)]', 'dark:border-[var(--color-border-dark)]', 'text-[var(--color-text-secondary-light)]', 'dark:text-[var(--color-text-secondary-dark)]');

      posts.forEach((post) => {
        if (tag === 'all') {
          post.style.display = '';
        } else {
          const postTags: string[] = JSON.parse(post.dataset.tags || '[]');
          post.style.display = postTags.includes(tag) ? '' : 'none';
        }
      });
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        selectTag(btn.dataset.tag!);
      });
    });

    // Auto-select tag from URL query param
    const urlTag = new URLSearchParams(window.location.search).get('tag');
    if (urlTag) selectTag(urlTag);
  });
</script>
