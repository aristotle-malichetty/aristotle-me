---
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import BlogCard from '@components/BlogCard.astro';
import ProjectCard from '@components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { ArrowRight, Quote } from '@lucide/astro';

const testimonials = [
  {
    quote: 'He turns complex datasets into clear insights and builds automations that reduce manual work and improve efficiency. His work has directly supported our growth and operational improvements.',
    name: 'Biswajit Pradhan',
    role: 'CEO, Digital Domination',
    image: '/images/testimonials/biswajit-pradhan.webp',
  },
  {
    quote: 'Aristotle consistently delivers thoughtful, data-driven solutions and explains complex ideas with clarity and balance. Strategic, reliable, and a strong contributor on cross-functional initiatives.',
    name: 'Fernando Ortiz, HCCP',
    role: 'Regional Manager, Equity Management Partners',
    image: '/images/testimonials/fernando-ortiz.webp',
  },
];

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Aristotle Malichetty',
  url: 'https://aristotle.me',
  sameAs: [
    'https://linkedin.com/in/aristotlem',
    'https://github.com/aristotle-malichetty',
    'https://x.com/aristotle_me',
  ],
  jobTitle: 'Marketing Analyst & Product Builder',
};

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'aristotle.me',
  url: 'https://aristotle.me',
};
---

<BaseLayout
  title="aristotle.me - Analytics, Products, and AI"
  description="Aris Malichetty — marketing analyst, product builder, and developer who builds with AI."
>
  <Hero />

  <!-- Latest Posts -->
  {latestPosts.length > 0 && (
    <section class="py-20 sm:py-24 section-alt">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="flex items-end justify-between mb-10">
          <div>
            <p class="text-xs font-medium uppercase tracking-[0.15em] text-[var(--color-accent-hover)] mb-2">From the blog</p>
            <h2 class="font-display text-2xl sm:text-3xl font-bold">Latest Posts</h2>
          </div>
          <a
            href="/blog"
            aria-label="View all posts"
            class="group hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] hover:text-[var(--color-accent)] transition-colors"
          >
            View all
            <ArrowRight class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5" />
          </a>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5">
          {latestPosts.map((post) => (
            <BlogCard
              slug={post.id}
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              tags={post.data.tags}
            />
          ))}
        </div>
        <div class="mt-6 sm:hidden text-center">
          <a
            href="/blog"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--color-accent-hover)] underline underline-offset-2 decoration-1"
          >
            View all posts <ArrowRight class="w-3.5 h-3.5" />
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Featured Projects -->
  {featuredProjects.length > 0 && (
    <section class="py-20 sm:py-24">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="flex items-end justify-between mb-10">
          <div>
            <p class="text-xs font-medium uppercase tracking-[0.15em] text-[var(--color-accent-hover)] mb-2">Things I've built</p>
            <h2 class="font-display text-2xl sm:text-3xl font-bold">Projects</h2>
          </div>
          <a
            href="/projects"
            aria-label="View all projects"
            class="group hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] hover:text-[var(--color-accent)] transition-colors"
          >
            View all
            <ArrowRight class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5" />
          </a>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {featuredProjects.map((project) => (
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              url={project.data.url}
              github={project.data.github}
              tags={project.data.tags}
              status={project.data.status}
            />
          ))}
        </div>
        <div class="mt-6 sm:hidden text-center">
          <a
            href="/projects"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--color-accent)] underline underline-offset-2 decoration-1"
          >
            View all projects <ArrowRight class="w-3.5 h-3.5" />
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Testimonials -->
  <section class="py-20 sm:py-24 section-alt">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <p class="text-xs font-medium uppercase tracking-[0.15em] text-[var(--color-accent-hover)] mb-2">What people say</p>
        <h2 class="font-display text-2xl sm:text-3xl font-bold mb-3">Trusted by 40+ clients</h2>
        <div class="flex items-center justify-center gap-1">
          {[...Array(5)].map(() => (
            <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
          ))}
          <span class="ml-1.5 text-sm text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)]">25+ reviews</span>
        </div>
      </div>
      <div class="grid sm:grid-cols-2 gap-5">
        {testimonials.map(({ quote, name, role, image }) => (
          <div class="relative p-7 sm:p-10 rounded-xl border border-[var(--color-border-light)] dark:border-[var(--color-border-dark)] bg-[var(--color-card-elevated-light)] dark:bg-[var(--color-card-elevated-dark)]">
            <Quote class="w-8 h-8 text-[var(--color-accent)]/20 absolute top-7 right-7 sm:top-10 sm:right-10" />
            <p class="text-[15px] sm:text-base text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] leading-relaxed mb-8 relative">
              {quote}
            </p>
            <div class="flex items-center gap-3">
              {image ? (
                <img
                  src={image}
                  alt={name}
                  width="48"
                  height="48"
                  class="w-12 h-12 rounded-full object-cover"
                />
              ) : (
                <div class="w-12 h-12 rounded-full bg-[var(--color-accent)]/10 flex items-center justify-center">
                  <span class="text-sm font-bold text-[var(--color-accent)]">{name.split(' ').map(n => n[0]).join('').slice(0, 2)}</span>
                </div>
              )}
              <div>
                <p class="text-sm font-semibold">{name}</p>
                <p class="text-xs text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)]">{role}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 sm:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="max-w-xl mx-auto text-center">
        <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold mb-4">Let's build something</h2>
        <p class="text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] mb-8 leading-relaxed">
          Have a project in mind — or a problem that needs solving? Let's talk.
        </p>
        <a
          href="/contact"
          class="group inline-flex items-center gap-2.5 px-7 py-3.5 rounded-lg bg-[var(--color-accent)] text-white font-medium hover:bg-[var(--color-accent-hover)] transition-all duration-200"
        >
          Get in Touch
          <ArrowRight class="w-4 h-4 transition-transform group-hover:translate-x-0.5" />
        </a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(personLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />
</BaseLayout>
