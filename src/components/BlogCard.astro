---
import TagList from './TagList.astro';

interface Props {
  slug: string;
  title: string;
  description: string;
  date: Date;
  tags?: string[];
  readingTime?: string;
}

const { slug, title, description, date, tags = [], readingTime } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a
  href={`/blog/${slug}`}
  class="group block p-4 sm:p-6 rounded-xl border border-[var(--color-border-light)] dark:border-[var(--color-border-dark)] bg-[var(--color-card-elevated-light)] dark:bg-[var(--color-card-elevated-dark)] hover:border-[var(--color-accent)]/50 hover:-translate-y-1 transition-all duration-300"
>
  <div class="flex items-center gap-3 text-sm text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] mb-3">
    <time datetime={date.toISOString()}>{formattedDate}</time>
    {readingTime && (
      <>
        <span>&middot;</span>
        <span>{readingTime}</span>
      </>
    )}
  </div>
  <h3 class="font-display text-base sm:text-lg font-semibold mb-2 group-hover:text-[var(--color-accent)] transition-colors">
    {title}
  </h3>
  <p class="text-sm text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] leading-relaxed mb-3 sm:mb-4 line-clamp-2">
    {description}
  </p>
  {tags.length > 0 && <TagList tags={tags} />}
</a>
