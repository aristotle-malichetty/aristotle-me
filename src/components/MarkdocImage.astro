---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata | string;
  alt: string;
  title?: string;
}

const { src, alt, title } = Astro.props;
const isOptimized = typeof src !== 'string';
---

{isOptimized ? (
  <Image
    src={src}
    alt={alt}
    title={title}
    widths={[480, 768, 1024]}
    sizes="(max-width: 680px) 100vw, 680px"
    loading="lazy"
  />
) : (
  <img
    src={src}
    alt={alt}
    title={title}
    loading="lazy"
  />
)}
