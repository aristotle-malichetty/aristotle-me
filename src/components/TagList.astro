---
interface Props {
  tags: string[];
  class?: string;
  linked?: boolean;
}

const { tags, class: className = '', linked = false } = Astro.props;
---

<div class:list={['flex gap-1.5 sm:gap-2', className.includes('flex-nowrap') ? '' : 'flex-wrap', className]}>
  {tags.map((tag) => (
    linked ? (
      <a href={`/blog?tag=${encodeURIComponent(tag)}`} class="inline-block px-2 sm:px-2.5 py-0.5 sm:py-1 text-[11px] sm:text-xs font-medium rounded-full bg-[var(--color-accent)]/10 text-[var(--color-accent)] whitespace-nowrap hover:bg-[var(--color-accent)]/20 transition-colors">
        {tag}
      </a>
    ) : (
      <span class="inline-block px-2 sm:px-2.5 py-0.5 sm:py-1 text-[11px] sm:text-xs font-medium rounded-full bg-[var(--color-accent)]/10 text-[var(--color-accent)] whitespace-nowrap">
        {tag}
      </span>
    )
  ))}
</div>
