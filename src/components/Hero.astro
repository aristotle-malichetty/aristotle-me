---
import { ArrowRight, ChevronRight } from '@lucide/astro';
---

<section class="relative py-24 sm:py-32 lg:py-40 overflow-hidden">
  <!-- Subtle ambient glow -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/4 right-0 w-[500px] h-[500px] rounded-full bg-[var(--color-accent)]/[0.04] dark:bg-[var(--color-accent)]/[0.06] blur-[100px]"></div>
  </div>

  <div class="relative max-w-5xl mx-auto px-4 sm:px-6">
    <div class="max-w-3xl stagger">
      <div class="flex items-center gap-3 mb-6">
        <span class="inline-block w-8 h-[2px] bg-[var(--color-accent)]"></span>
        <span class="text-sm font-medium tracking-wide text-[var(--color-accent)]">Analytics &middot; Products &middot; AI</span>
      </div>

      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight leading-[1.1] mb-6">
        Hi, I'm <span class="text-[var(--color-accent)]">Aris</span>
      </h1>

      <p class="text-lg sm:text-xl text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] max-w-xl leading-relaxed mb-10">
        Marketing analyst who codes. I find what works, build what's missing, and automate the rest.
      </p>

      <div class="flex flex-wrap items-center gap-4">
        <a
          href="/projects"
          class="group inline-flex items-center gap-2.5 px-6 py-3 rounded-lg bg-[var(--color-accent)] text-white font-medium hover:bg-[var(--color-accent-hover)] transition-all duration-200"
        >
          View Projects
          <ArrowRight class="w-4 h-4 transition-transform group-hover:translate-x-0.5" />
        </a>
        <a
          href="/blog"
          class="group inline-flex items-center gap-1.5 text-sm font-medium text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] hover:text-[var(--color-accent)] transition-colors"
        >
          Read the Blog
          <ChevronRight class="w-4 h-4 transition-transform group-hover:translate-x-0.5" />
        </a>
      </div>
    </div>
  </div>
</section>
