---
import { ArrowRight, ChevronRight } from '@lucide/astro';
---

<section class="relative py-20 sm:py-24 lg:py-32 overflow-hidden">
  <!-- Subtle ambient glow -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[600px] rounded-full bg-[var(--color-accent)]/[0.04] dark:bg-[var(--color-accent)]/[0.06] blur-[100px]"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center stagger">
      <div class="flex items-center justify-center gap-3 mb-8">
        <span class="text-base font-medium tracking-wide text-[var(--color-accent)]">Analytics &middot; Products &middot; AI</span>
      </div>

      <h1 class="font-display text-6xl sm:text-7xl lg:text-8xl font-bold tracking-tight leading-[1.05] mb-8">
        Hi, I'm <span class="text-[var(--color-accent)]">Aris</span>
      </h1>

      <p class="text-xl sm:text-2xl text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] max-w-2xl mx-auto leading-relaxed mb-12">
        Marketing analyst who codes. I find what works, build what's missing, and automate the rest.
      </p>

      <div class="flex flex-wrap items-center justify-center gap-5">
        <a
          href="/projects"
          class="group inline-flex items-center gap-2.5 px-8 py-4 rounded-lg bg-[var(--color-accent)] text-white text-lg font-medium hover:bg-[var(--color-accent-hover)] transition-all duration-200"
        >
          View Projects
          <ArrowRight class="w-5 h-5 transition-transform group-hover:translate-x-0.5" />
        </a>
        <a
          href="/blog"
          class="group inline-flex items-center gap-1.5 text-base font-medium text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] hover:text-[var(--color-accent)] transition-colors"
        >
          Read the Blog
          <ChevronRight class="w-5 h-5 transition-transform group-hover:translate-x-0.5" />
        </a>
      </div>
    </div>
  </div>
</section>
