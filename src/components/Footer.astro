---
import { Github, Linkedin, Twitter, Mail } from '@lucide/astro';

const year = new Date().getFullYear();

const socialLinks = [
  { href: 'https://github.com/aristotlem', label: 'GitHub', icon: Github },
  { href: 'https://linkedin.com/in/aristotlem', label: 'LinkedIn', icon: Linkedin },
  { href: 'https://x.com/aristotlem', label: 'X', icon: Twitter },
  { href: 'mailto:mailaristotle@gmail.com', label: 'Email', icon: Mail },
];
---

<footer class="border-t border-[var(--color-border-light)] dark:border-[var(--color-border-dark)] mt-20">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)]">
        &copy; {year} Aristotle Malichetty. Built with Astro + Claude Code.
      </p>
      <div class="flex items-center gap-4">
        {socialLinks.map(({ href, label, icon: Icon }) => (
          <a
            href={href}
            target={href.startsWith('mailto') ? undefined : '_blank'}
            rel={href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
            aria-label={label}
            class="text-[var(--color-text-secondary-light)] dark:text-[var(--color-text-secondary-dark)] hover:text-[var(--color-accent)] transition-colors"
          >
            <Icon class="w-5 h-5" />
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
